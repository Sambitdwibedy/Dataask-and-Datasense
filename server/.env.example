# ─────────────────────────────────────────────────────────────────────────────
# IDA — Intelligent Data Assistant  |  Environment Variables
# Copy this file to .env for local development.
# For Vercel: add each variable in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Vercel ignores this — it manages ports automatically)
PORT=3002

# PostgreSQL connection string
# Vercel: use Vercel Postgres, Neon, Supabase, or your existing Railway DB URL
DATABASE_URL=postgresql://user:pass@localhost:5432/bokg_builder

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# CORS — set to your Vercel deployment URL in production
# e.g. https://your-app.vercel.app
CORS_ORIGIN=*

# AI API Keys (required for NL2SQL and document processing)
ANTHROPIC_API_KEY=sk-ant-v0-...
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL DEPLOYMENT NOTES
# ─────────────────────────────────────────────────────────────────────────────
# 1. DATABASE_URL  → Your existing Railway/Supabase/Neon PostgreSQL URL
# 2. JWT_SECRET    → Generate a strong random string (e.g. `openssl rand -hex 32`)
# 3. CORS_ORIGIN   → Set to your Vercel app URL once deployed
#                    e.g. https://data-ask.vercel.app
# 4. File uploads  → Vercel's serverless functions use an ephemeral filesystem.
#                    Uploaded files survive only for the duration of one request.
#                    For persistent uploads, integrate an S3/R2/Blob storage.
# ─────────────────────────────────────────────────────────────────────────────
