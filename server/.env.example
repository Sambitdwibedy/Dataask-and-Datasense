# ─────────────────────────────────────────────────────────────────────────────
# IDA — Intelligent Data Assistant  |  Environment Variables
# Copy this file to .env for local development.
# For Vercel: add each variable in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Vercel ignores this — it manages ports automatically)
PORT=3002

# MySQL connection string
# Local:      mysql://user:pass@localhost:3306/ida_dataask
# PlanetScale: mysql://user:pass@host.us-east.psdb.cloud/ida_dataask?ssl={"rejectUnauthorized":true}
# Railway:    mysql://root:pass@containers-us-west-X.railway.app:PORT/railway
# Aiven:      mysql://user:pass@host.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=mysql://user:pass@localhost:3306/ida_dataask

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# CORS — set to your Vercel deployment URL in production
CORS_ORIGIN=*

# AI API Keys (required for NL2SQL and document processing)
ANTHROPIC_API_KEY=sk-ant-v0-...
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL DEPLOYMENT NOTES
# ─────────────────────────────────────────────────────────────────────────────
# 1. DATABASE_URL  → Use PlanetScale (free tier) or Railway MySQL
#                    PlanetScale: https://planetscale.com (recommended)
#                    Railway: https://railway.app → New → MySQL
# 2. JWT_SECRET    → Generate with: openssl rand -hex 32
# 3. CORS_ORIGIN   → https://your-app.vercel.app (set after first deploy)
# 4. Run schema    → After DB is ready: node server/init-db.js
# ─────────────────────────────────────────────────────────────────────────────
